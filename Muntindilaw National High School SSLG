<script>
        function changePage(id) {
            document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
            document.getElementById(id).classList.add('active');
            document.getElementById('aboutMenu').classList.remove('show');
            window.scrollTo(0,0);
        }
        
        function openGallery(title, images) {
    const modal = document.getElementById('gModal');
    const grid = document.getElementById('gGrid');
    const gTitle = document.getElementById('gTitle');

    gTitle.innerText = title;
    grid.innerHTML = ''; // Linisin muna ang grid

    images.forEach(src => {
        let img = document.createElement('img');
        img.src = src;
        img.style.width = "100%";
        img.style.maxWidth = "200px";
        img.style.height = "150px";
        img.style.objectFit = "cover";
        img.style.borderRadius = "10px";
        grid.appendChild(img);
    });

    modal.style.display = 'flex';
}

function closeGallery() {
    document.getElementById('gModal').style.display = 'none';
}

// Para masara ang modal kapag clinick ang labas nito
window.onclick = function(event) {
    let modal = document.getElementById('gModal');
    if (event.target == modal) {
        closeGallery();
    }
}

        function toggleAbout() {
    document.getElementById("aboutMenu").classList.toggle("show");
}
        

        function closeGallery() { document.getElementById('gModal').style.display = 'none'; }

        document.getElementById('fForm').onsubmit = function(e) {
            e.preventDefault();
            let n = document.getElementById('uName'), e_m = document.getElementById('uEmail');
            let nV = /^[A-Za-z\s]+$/.test(n.value), eV = e_m.value.toLowerCase().endsWith("@gmail.com");

            n.classList.toggle('input-error', !nV);
            document.getElementById('nErr').style.display = nV ? 'none' : 'block';
            if (eV && nV){alert("Error"); this.reset();}
            e_m.classList.toggle('input-error', !eV);
            document.getElementById('eErr').style.display = eV ? 'none' : 'block';

            if(nV && eV) { alert("Thank you for your Feedback!"); this.reset(); }
        }
    </script>
